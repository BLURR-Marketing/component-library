---
import { COMPONENTS, CATEGORIES } from '../data/components';
import '../styles/showcase.css';

interface Props {
  title?: string;
  activeSlug?: string;
}

const { title = 'BLURR Component Library', activeSlug } = Astro.props;

const GITHUB_URL = 'https://github.com/BLURR-Marketing/component-library';

// Group components by category for sidebar
const grouped = CATEGORIES.filter(c => c.id !== 'all').map(cat => ({
  ...cat,
  items: COMPONENTS.filter(c => c.category === cat.id),
}));
---

<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content="22 herbruikbare Astro componenten voor BLURR Marketing websites." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body>
  <div class="sc-wrapper">

    <!-- Header -->
    <header class="sc-header">
      <a href="/" class="sc-logo">
        <span class="sc-logo-dot"></span>
        BLURR Components
      </a>

      <div class="sc-header-spacer"></div>

      <span class="sc-header-search">
        <svg width="13" height="13" viewBox="0 0 16 16" fill="none"><circle cx="6.5" cy="6.5" r="5" stroke="currentColor" stroke-width="1.5"/><path d="M10.5 10.5L14 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        Zoeken... &nbsp;<kbd>⌘K</kbd>
      </span>

      <a href={GITHUB_URL} class="sc-header-link" target="_blank" rel="noopener">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
        GitHub
      </a>

      <button class="sc-hamburger" aria-label="Menu" id="hamburger">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor"><rect y="3" width="20" height="2" rx="1"/><rect y="9" width="20" height="2" rx="1"/><rect y="15" width="20" height="2" rx="1"/></svg>
      </button>
    </header>

    <!-- Sidebar -->
    <aside class="sc-sidebar" id="sidebar">
      <a href="/" class="sc-sidebar-all">
        Alle componenten
        <span class="sc-sidebar-count">{COMPONENTS.length}</span>
      </a>
      <div class="sc-sidebar-divider"></div>

      {grouped.map(cat => cat.items.length > 0 && (
        <div class="sc-sidebar-section">
          <span class="sc-sidebar-section-title">{cat.label}</span>
          {cat.items.map(item => (
            <a
              href={`/${item.slug}`}
              class:list={['sc-sidebar-link', { 'is-active': activeSlug === item.slug }]}
            >
              {item.name}
            </a>
          ))}
        </div>
      ))}

      <div class="sc-sidebar-divider"></div>
      <div class="sc-sidebar-section">
        <a href={GITHUB_URL} class="sc-sidebar-link" target="_blank" rel="noopener">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" style="opacity:0.5"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub ↗
        </a>
      </div>
    </aside>

    <!-- Main -->
    <main class="sc-main">
      <slot />
    </main>

  </div>

  <script>
    // Mobile hamburger
    const btn = document.getElementById('hamburger');
    const sidebar = document.getElementById('sidebar');
    btn?.addEventListener('click', () => sidebar?.classList.toggle('is-open'));
    document.addEventListener('click', (e) => {
      if (sidebar?.classList.contains('is-open') && !sidebar.contains(e.target as Node) && e.target !== btn) {
        sidebar.classList.remove('is-open');
      }
    });

    // Global keyboard search shortcut (⌘K)
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        const search = document.getElementById('main-search') as HTMLInputElement;
        search?.focus();
      }
    });
  </script>
</body>
</html>

<style>
.ta{background:var(--color-bg, #fff);padding:5rem 1.5rem}
.ta__inner{max-width:1100px;margin:0 auto}
.ta__header{text-align:center;margin-bottom:4rem}
.ta__eyebrow{font-size:.75rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--color-accent, #6366f1);margin-bottom:.75rem}
.ta__title{font-size:clamp(1.875rem,3vw,2.75rem);font-weight:800;letter-spacing:-.03em;color:var(--color-primary, #0a0a0a)}
.ta__title em{font-style:normal;color:var(--color-accent, #6366f1)}
.ta__row{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;padding:4rem 0;border-top:1px solid rgba(0,0,0,.07)}
.ta__row--reversed{direction:rtl}
.ta__row--reversed>{direction:ltr}
.ta__photo{position:relative}
.ta__photo img{width:100%;height:480px;object-fit:cover;object-position:top;border-radius:calc(var(--radius, .5rem) * 2);display:block}
.ta__quote-card{position:absolute;bottom:-1.5rem;right:-1.5rem;background:#fff;border:1px solid rgba(0,0,0,.07);border-radius:calc(var(--radius, .5rem) * 1.5);padding:1.25rem;max-width:240px;box-shadow:0 12px 32px #00000014}
.ta__row--reversed .ta__quote-card{right:auto;left:-1.5rem}
.ta__quote-text{font-size:.875rem;line-height:1.6;color:var(--color-primary, #0a0a0a);font-style:italic}
.ta__member-role{font-size:.8125rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--color-accent, #6366f1);margin-bottom:.5rem}
.ta__member-name{font-size:clamp(1.5rem,2.5vw,2.25rem);font-weight:800;letter-spacing:-.02em;color:var(--color-primary, #0a0a0a);margin-bottom:1rem}
.ta__bio{font-size:1rem;line-height:1.75;color:var(--color-muted, #6b7280);margin-bottom:2rem}
.ta__facts{display:flex;gap:2rem;padding:1.5rem 0;border-top:1px solid rgba(0,0,0,.07);border-bottom:1px solid rgba(0,0,0,.07);margin-bottom:1.5rem}
.ta__fact-value{font-size:1.75rem;font-weight:800;letter-spacing:-.03em;color:var(--color-primary, #0a0a0a)}
.ta__fact-label{font-size:.8125rem;color:var(--color-muted, #6b7280);margin-top:.125rem}
.ta__linkedin{display:inline-flex;align-items:center;gap:.5rem;color:var(--color-accent, #6366f1);font-size:.9rem;font-weight:600;text-decoration:none}
.ta__linkedin:hover{opacity:.7}
.ta__row{grid-template-columns:1fr;gap:2rem}
.ta__row--reversed{direction:ltr}
.ta__photo img{height:300px}
.ta__quote-card{display:none}
</style>

<div class="preview-wrapper--centered" data-astro-cid-5gxsex3c> <div style="display:flex;flex-direction:column;gap:1.5rem;width:100%;max-width:400px" data-astro-cid-5gxsex3c> <div class="if if--md" data-component="input-field" data-astro-cid-ra7ei5a2> <label class="if__label" for="input-htwgm" data-astro-cid-ra7ei5a2> E-mailadres <span class="if__required" aria-hidden="true" data-astro-cid-ra7ei5a2>*</span> </label> <div class="if__wrap" data-astro-cid-ra7ei5a2>  <input id="input-htwgm" type="email" class="if__input" placeholder="naam@bedrijf.nl" required aria-describedby="input-htwgm-helper" data-astro-cid-ra7ei5a2>   </div>  <p class="if__message" id="input-htwgm-helper" data-astro-cid-ra7ei5a2>We sturen alleen relevante updates.</p> </div>   <div class="if if--md" data-component="input-field" data-astro-cid-ra7ei5a2> <label class="if__label" for="input-6vdyu" data-astro-cid-ra7ei5a2> Wachtwoord  </label> <div class="if__wrap" data-astro-cid-ra7ei5a2>  <input id="input-6vdyu" type="password" class="if__input" placeholder="Minimaal 8 tekens" data-astro-cid-ra7ei5a2>  <button type="button" class="if__toggle-pw" aria-label="Toon/verberg wachtwoord" data-astro-cid-ra7ei5a2> <svg class="if__pw-show" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" data-astro-cid-ra7ei5a2> <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" data-astro-cid-ra7ei5a2></path> <circle cx="12" cy="12" r="3" data-astro-cid-ra7ei5a2></circle> </svg> </button> </div>   </div> <script>
    document.querySelectorAll('[data-component="input-field"]').forEach(field => {
      const btn = field.querySelector<HTMLButtonElement>('.if__toggle-pw');
      const input = field.querySelector<HTMLInputElement>('.if__input');
      if (btn && input) {
        btn.addEventListener('click', () => {
          input.type = input.type === 'password' ? 'text' : 'password';
        });
      }
    });
  </script>  <div class="if if--md" data-component="input-field" data-astro-cid-ra7ei5a2> <label class="if__label" for="input-wknct" data-astro-cid-ra7ei5a2> Opmerkingen  </label> <div class="if__wrap" data-astro-cid-ra7ei5a2>  <textarea id="input-wknct" class="if__input if__textarea" placeholder="Vertel ons meer..." rows="3" data-astro-cid-ra7ei5a2></textarea>   </div>   </div>   <div class="if if--md if--error" data-component="input-field" data-astro-cid-ra7ei5a2> <label class="if__label" for="input-cibwr" data-astro-cid-ra7ei5a2> Fout voorbeeld  </label> <div class="if__wrap" data-astro-cid-ra7ei5a2>  <input id="input-cibwr" type="text" class="if__input" placeholder="Vul in..." value="fout" aria-invalid="true" aria-describedby="input-cibwr-error" data-astro-cid-ra7ei5a2>   </div> <p class="if__message if__message--error" id="input-cibwr-error" role="alert" data-astro-cid-ra7ei5a2>Dit veld is verplicht.</p>  </div>   </div> </div>



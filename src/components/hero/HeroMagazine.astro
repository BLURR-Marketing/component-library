<style>
.hm{min-height:100vh;display:flex;flex-direction:column;background:var(--color-bg, #fff);overflow:hidden;border-bottom:1px solid var(--color-primary, #0a0a0a)}
.hm__inner{flex:1;display:grid;grid-template-columns:120px 1fr 340px;gap:0}

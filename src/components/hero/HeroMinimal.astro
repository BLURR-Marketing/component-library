<section class="hm hm--center"> <div class="hm-inner"> <p class="hm-eyebrow">Premium Online Marketing</p> <h1 class="hm-headline">Groei die blijft.</h1> <p class="hm-sub">Wij bouwen campagnes die niet alleen converteren, maar ook duurzame merkwaarde creëren.</p> <div class="hm-actions"> <a href="#" class="hm-btn hm-btn--primary">Begin vandaag</a> <a href="#" class="hm-btn hm-btn--ghost">Meer weten</a> </div> </div> </section>

<style>
.hm{padding:8rem 2rem 7rem;background:#fff}
.hm--center{text-align:center}
.hm--left{text-align:left}
.hm-inner{max-width:720px}
.hm--center .hm-inner{margin:0 auto}
.hm-eyebrow{font-size:.6875rem;letter-spacing:.18em;text-transform:uppercase;color:#9ca3af;margin-bottom:1.5rem}
.hm-headline{font-size:clamp(2.5rem,5vw,5rem);font-weight:300;letter-spacing:-.04em;line-height:1.1;color:#0a0a0a;margin:0 0 1.5rem}
.hm-sub{font-size:1.0625rem;color:#6b7280;line-height:1.7;max-width:560px;margin:0 auto 2.5rem}
.hm--left .hm-sub{margin-left:0}
.hm-actions{display:flex;gap:1rem;flex-wrap:wrap;justify-content:center}
.hm--left .hm-actions{justify-content:flex-start}
.hm-btn{display:inline-flex;align-items:center;padding:.75rem 2rem;font-size:.875rem;font-weight:500;letter-spacing:.04em;text-decoration:none;transition:all .2s}
.hm-btn--primary{background:#0a0a0a;color:#fff}
.hm-btn--primary:hover{background:#1a1a1a}
.hm-btn--ghost{border:1px solid #d1d5db;color:#374151}
.hm-btn--ghost:hover{border-color:#9ca3af;color:#0a0a0a}
</style>

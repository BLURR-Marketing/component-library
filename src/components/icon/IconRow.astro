---
// IconRow — recovered from blurr-components.pages.dev
---

<div class="irow">  <div class="irow__items">  <div class="irow__item"> <span class="irow__icon" aria-hidden="true">🏆</span> <div class="irow__text"> <p class="irow__sublabel">2024</p> <p class="irow__label">Bureau van het jaar</p> </div> </div> <span class="irow__sep" aria-hidden="true">·</span> <div class="irow__item"> <span class="irow__icon" aria-hidden="true">👥</span> <div class="irow__text"> <p class="irow__sublabel">80+</p> <p class="irow__label">Tevreden klanten</p> </div> </div> <span class="irow__sep" aria-hidden="true">·</span> <div class="irow__item"> <span class="irow__icon" aria-hidden="true">📈</span> <div class="irow__text"> <p class="irow__sublabel">4.2x</p> <p class="irow__label">Gem. ROAS</p> </div> </div> <span class="irow__sep" aria-hidden="true">·</span> <div class="irow__item"> <span class="irow__icon" aria-hidden="true">⭐</span> <div class="irow__text"> <p class="irow__sublabel">4.9/5</p> <p class="irow__label">Google rating</p> </div> </div> <span class="irow__sep" aria-hidden="true">·</span> <div class="irow__item"> <span class="irow__icon" aria-hidden="true">🚀</span> <div class="irow__text"> <p class="irow__sublabel">300+</p> <p class="irow__label">Projecten</p> </div> </div>  </div> </div>

<style>
.irow{padding:1rem 0}
.irow--centered .irow__items{justify-content:center}
.irow__title{font-size:1.25rem;font-weight:700;color:var(--color-primary, #0a0a0a);margin:0 0 1.25rem}
.irow__items{display:flex;flex-wrap:wrap;align-items:center;gap:.5rem 1rem}
.irow__item{display:flex;align-items:center;gap:.6rem}
.irow__icon{font-size:1.4rem}
.irow__text{display:flex;flex-direction:column}
.irow__sublabel{font-size:1.1rem;font-weight:800;color:var(--color-primary, #0a0a0a);margin:0;line-height:1}
.irow__label{font-size:.75rem;color:#888;margin:0;font-weight:500}
.irow__sep{color:#ddd;font-size:1.5rem;line-height:1;user-select:none}
.irow__sep{display:none}
.irow__items{gap:1rem}
</style>

<style>
.vt2{background:#f9f9fb;padding:4rem 1.5rem}
.vt2__inner{max-width:1000px;margin:0 auto}
.vt2__headline{font-size:1.75rem;font-weight:700;color:var(--color-primary, #0a0a0a);margin:0 0 2rem}
.vt2__grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:1.25rem}
.vt2__card{border-radius:12px;overflow:hidden;background:#fff;box-shadow:0 2px 12px #0000000f;transition:transform .2s,box-shadow .2s;cursor:pointer}
.vt2__card:hover{transform:translateY(-4px);box-shadow:0 8px 28px #0000001f}
.vt2__thumb{aspect-ratio:4/3;background:var(--card-bg, #1e1b4b);display:flex;align-items:center;justify-content:center;position:relative}
.vt2__play-btn{background:#ffffff26;border:2px solid rgba(255,255,255,.4);width:52px;height:52px;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .2s}
.vt2__play-btn:hover{background:#ffffff47}
.vt2__play-icon{color:#fff;font-size:1.1rem;padding-left:3px}
.vt2__dur{position:absolute;bottom:.5rem;right:.6rem;background:#000000a6;color:#fff;font-size:.7rem;font-weight:600;padding:.15rem .4rem;border-radius:4px;font-variant-numeric:tabular-nums}
.vt2__info{padding:.85rem 1rem}
.vt2__name{font-size:.9rem;font-weight:700;color:var(--color-primary, #0a0a0a);margin:0 0 .2rem}
.vt2__role{font-size:.76rem;color:#888;margin:0}
</style>

.ipr__bio{font-size:.9rem;color:#555;line-height:1.6;margin:0 0 .75rem}
.ipr__link{font-size:.85rem;font-weight:600;color:var(--color-accent, #6366f1);text-decoration:none}
.ipr__link:hover{text-decoration:underline}

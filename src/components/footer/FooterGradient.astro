.fg2-col-title{font-size:.6875rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#ffffff80;margin:0 0 1rem}
.fg2-col-links{list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:.5rem}

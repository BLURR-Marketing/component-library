.nlr-cta:hover{background:#0a0a0a;color:#fff}
.nlr-logo{font-weight:800;font-size:1.0625rem;color:#0a0a0a;text-decoration:none;letter-spacing:-.02em;white-space:nowrap;margin-left:1rem}

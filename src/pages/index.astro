---
import ShowcaseLayout from '../layouts/ShowcaseLayout.astro';
import { COMPONENTS, CATEGORIES, STARTER_PACKS } from '../data/components';

const categoryMap: Record<string, string> = {
  nav: 'Navigation',
  hero: 'Hero',
  sections: 'Sections',
  'social-proof': 'Social Proof',
  cta: 'CTA',
  forms: 'Forms',
  footer: 'Footer',
  ui: 'UI Elements',
};

// Build slug sets per starter pack for client-side use
const packSlugs = Object.fromEntries(
  STARTER_PACKS.map(p => [
    p.id,
    [p.components.nav, p.components.hero, ...p.components.sections, ...p.components.socialProof, p.components.cta, ...(p.components.forms ? [p.components.forms] : []), p.components.footer],
  ])
);
---

<ShowcaseLayout title="BLURR Component Library">
  <div class="sc-grid-header">
    <h1 class="sc-grid-title">Component Library</h1>
    <p class="sc-grid-sub">{COMPONENTS.length} herbruikbare Astro componenten — klik om live te bekijken.</p>
  </div>

  <input
    id="main-search"
    class="sc-search-bar"
    type="search"
    placeholder="Zoek component..."
    autocomplete="off"
    aria-label="Zoek component"
  />

  <!-- Starter Packs -->
  <div class="sc-section-label">Starter Packs</div>
  <div class="sc-filter-pills sc-packs">
    <button class="sc-pill sc-pack-pill is-active" data-pack="all">Alle</button>
    {STARTER_PACKS.map(pack => (
      <button
        class="sc-pill sc-pack-pill"
        data-pack={pack.id}
        title={pack.description}
      >
        {pack.label}
      </button>
    ))}
  </div>

  <!-- Category filter -->
  <div class="sc-section-label">Categorie</div>
  <div class="sc-filter-pills">
    {CATEGORIES.map(cat => (
      <button
        class:list={['sc-pill', { 'is-active': cat.id === 'all' }]}
        data-cat={cat.id}
      >
        {cat.label}
        {cat.id !== 'all' && (
          <span style="opacity:0.5;margin-left:3px;font-size:0.6875rem">
            ({COMPONENTS.filter(c => c.category === cat.id).length})
          </span>
        )}
      </button>
    ))}
  </div>

  <div class="sc-component-grid" id="component-grid">
    {COMPONENTS.map(comp => (
      <a
        href={`/${comp.slug}`}
        class="sc-component-card"
        data-category={comp.category}
        data-name={comp.name.toLowerCase()}
        data-slug={comp.slug}
        data-tags={comp.tags.join(',')}
      >
        <div class="sc-component-preview">
          <iframe
            src={`/preview/${comp.slug}`}
            title={`Preview van ${comp.name}`}
            loading="lazy"
            scrolling="no"
          ></iframe>
        </div>
        <div class="sc-component-info">
          <div class="sc-component-name">{comp.name}</div>
          <div class="sc-component-desc">{comp.description}</div>
        </div>
        <div class="sc-component-footer">
          <span class="sc-cat-badge">{categoryMap[comp.category] ?? comp.category}</span>
          <div class="sc-tag-list">
            {comp.tags.filter(t => !['utility','static'].includes(t)).slice(0,3).map(tag => (
              <span class="sc-tag">{tag}</span>
            ))}
          </div>
          <span class="sc-arrow">→</span>
        </div>
      </a>
    ))}
  </div>

  <div class="sc-empty" id="empty-state" style="display:none">
    <div class="sc-empty-icon">🔍</div>
    <div class="sc-empty-text">Geen componenten gevonden.</div>
  </div>
</ShowcaseLayout>

<style>
  .sc-component-preview iframe {
    width: 960px;
    height: 600px;
    transform: scale(0.3125);
    transform-origin: top left;
    pointer-events: none;
  }
  .sc-section-label {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.45;
    margin: 1.5rem 0 0.5rem;
  }
  .sc-tag-list {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
    flex: 1;
  }
  .sc-tag {
    font-size: 0.625rem;
    padding: 1px 6px;
    border-radius: 999px;
    background: var(--surface-2, #f0f0f0);
    color: var(--text-2, #666);
    font-weight: 500;
  }
  .sc-pack-pill.is-active {
    background: var(--color-accent, #4f46e5);
    color: #fff;
    border-color: transparent;
  }
</style>

<script define:vars={{ packSlugs }}>
  const searchInput = document.getElementById('main-search');
  const emptyState = document.getElementById('empty-state');
  const catPills = document.querySelectorAll('.sc-pill:not(.sc-pack-pill)');
  const packPills = document.querySelectorAll('.sc-pack-pill');
  const cards = document.querySelectorAll('.sc-component-card');

  let activeCategory = 'all';
  let activePack = 'all';
  let searchQuery = '';

  function filterCards() {
    let visible = 0;
    const packSet = activePack !== 'all' ? new Set(packSlugs[activePack] ?? []) : null;

    cards.forEach(card => {
      const cat = card.dataset.category ?? '';
      const name = card.dataset.name ?? '';
      const slug = card.dataset.slug ?? '';

      const matchesCat = activeCategory === 'all' || cat === activeCategory;
      const matchesPack = !packSet || packSet.has(slug);
      const matchesSearch = !searchQuery || name.includes(searchQuery) || (card.dataset.tags ?? '').includes(searchQuery);

      const show = matchesCat && matchesPack && matchesSearch;
      card.style.display = show ? '' : 'none';
      card.classList.toggle('is-pack-match', !!packSet && packSet.has(slug));
      if (show) visible++;
    });
    emptyState.style.display = visible === 0 ? 'block' : 'none';
  }

  // Starter pack filter
  packPills.forEach(pill => {
    pill.addEventListener('click', () => {
      activePack = pill.dataset.pack ?? 'all';
      packPills.forEach(p => p.classList.remove('is-active'));
      pill.classList.add('is-active');
      filterCards();
    });
  });

  // Category filter
  catPills.forEach(pill => {
    pill.addEventListener('click', () => {
      activeCategory = pill.dataset.cat ?? 'all';
      catPills.forEach(p => p.classList.remove('is-active'));
      pill.classList.add('is-active');
      filterCards();
    });
  });

  // Search (also searches tags)
  searchInput?.addEventListener('input', () => {
    searchQuery = searchInput.value.toLowerCase().trim();
    filterCards();
  });
</script>

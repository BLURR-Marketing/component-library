---

<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --color-primary: #0a0a0a;
      --color-accent: #6366f1;
      --color-bg: #ffffff;
      --color-text: #0a0a0a;
      --color-muted: #6b7280;
      --font-sans: 'Plus Jakarta Sans', system-ui, -apple-system, sans-serif;
      --font-display: var(--font-sans);
      --radius: 0.5rem;
    }

    html, body {
      background: #fff;
      font-family: var(--font-sans);
      -webkit-font-smoothing: antialiased;
    }

    /* Center small components */
    .preview-wrapper--centered {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 200px;
      padding: 2rem;
      background: #f9f9fb;
    }
  </style>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
</head>
<body>
  {Component ? (
    slug === 'button' || slug === 'badge' ? (
      <div class="preview-wrapper--centered">
        {slug === 'button' && (
          <div style="display:flex;gap:0.75rem;flex-wrap:wrap;align-items:center">
            <Button label="Primary" variant="primary" size="md" />
            <Button label="Secondary" variant="secondary" size="md" />
            <Button label="Ghost" variant="ghost" size="md" />
            <Button label="Danger" variant="danger" size="md" />
          </div>
        )}
        {slug === 'badge' && (
          <div style="display:flex;gap:0.5rem;flex-wrap:wrap;align-items:center">
            <Badge label="Default" variant="default" />
            <Badge label="Accent" variant="accent" />
            <Badge label="Success" variant="success" />
            <Badge label="Warning" variant="warning" />
            <Badge label="Danger" variant="danger" />
            <Badge label="Outline" variant="outline" />
          </div>
        )}
      </div>
    ) : slug === 'card' ? (
      <div class="preview-wrapper--centered">
        <div style="display:grid;grid-template-columns:repeat(2,240px);gap:1rem">
          <Card variant="default" padding="md">
            <p style="font-weight:700;margin-bottom:0.5rem">Default Card</p>
            <p style="font-size:0.875rem;color:var(--color-muted)">Grijze achtergrond, geen border.</p>
          </Card>
          <Card variant="bordered" padding="md">
            <p style="font-weight:700;margin-bottom:0.5rem">Bordered Card</p>
            <p style="font-size:0.875rem;color:var(--color-muted)">Witte achtergrond met rand.</p>
          </Card>
          <Card variant="elevated" padding="md">
            <p style="font-weight:700;margin-bottom:0.5rem">Elevated Card</p>
            <p style="font-size:0.875rem;color:var(--color-muted)">Schaduw, geen rand.</p>
          </Card>
          <Card variant="elevated" href="#" padding="md">
            <p style="font-weight:700;margin-bottom:0.5rem">Klikbare Card →</p>
            <p style="font-size:0.875rem;color:var(--color-muted)">Hover voor lift effect.</p>
          </Card>
        </div>
      </div>
    ) : (
      <Component {...p} />
    )
  ) : (
    <p style="padding:2rem;color:red">Component niet gevonden: {slug}</p>
  )}
</body>
</html>
